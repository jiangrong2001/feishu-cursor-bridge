# 飞书开放平台 → 事件订阅 → 加密密钥 / Verification Token
# https://open.feishu.cn/app
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=

# 可选：仅处理这些 open_id 发来的消息（逗号分隔）；留空表示不限制
# ALLOWED_SENDER_OPEN_IDS=ou_xxxx,ou_yyyy

# 服务监听
PORT=8787
WEBHOOK_PATH=/webhook/feishu

# 收到消息后是否在 macOS 上用 Cursor 打开 LATEST.md（1=开启）
CURSOR_OPEN_ON_MESSAGE=0

# 可选：收到命令后自动在飞书回一条「已收到」（需机器人有发消息权限）
# LARK_APP_ID=
# LARK_APP_SECRET=
# LARK_AUTO_ACK=1
