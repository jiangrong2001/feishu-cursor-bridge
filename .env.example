# ========== 飞书长连接 ==========
LARK_APP_ID=
LARK_APP_SECRET=

PORT=8787

# ========== Cursor Agent 全自动（飞书 ↔ 本机 agent）==========
# 安装 CLI：curl https://cursor.com/install -fsS | bash，然后 agent login
CURSOR_AGENT_AUTO=1
# PATH 中的可执行文件名，一般为 agent
# CURSOR_AGENT_BIN=agent
# Agent 工作区（默认本仓库根目录，建议改为你的项目绝对路径）
# CURSOR_AGENT_WORKSPACE=
CURSOR_AGENT_SANDBOX=disabled
# CURSOR_AGENT_MODEL=
# 飞书进度推送最小间隔（毫秒，仅当 STREAM_TO_FEISHU=1 时有效）
# CURSOR_AGENT_FEISHU_MIN_INTERVAL_MS=5000
# 1/true：把工具调用等过程也发到飞书；默认关，飞书里通常只有一条简洁答复
# CURSOR_AGENT_STREAM_TO_FEISHU=0
# 飞书消息以 /v、/verbose、/verbos 开头时的「对话摘录」块之间的最小间隔（毫秒）；默认 350；0=尽量紧接发送
# CURSOR_AGENT_TRANSCRIPT_MIN_INTERVAL_MS=350
# 安静模式：仅当未确认 lark-cli 已成功发到飞书时由桥接 API 补发正文（默认开，避免空白且不重复）
# CURSOR_AGENT_QUIET_BRIDGE_FALLBACK=1
# agent 最长运行毫秒，超时 SIGTERM；0=不限制；启动校验 0～约 24h
# CURSOR_AGENT_TIMEOUT_MS=0
# 待执行 Agent 队列上限；默认 30；0=不限制（生产勿用）；启动校验 0～500
# CURSOR_AGENT_MAX_QUEUE=30
# 可选；不填则用 agent login 本机凭据
# CURSOR_API_KEY=

# ========== 安全与限制（详见 README.zh.md §七）==========
# 逗号分隔 ou_xxx；未配置时凡能私聊/群聊机器人者均可触发本机 Agent
# ALLOWED_SENDER_OPEN_IDS=ou_xxx,ou_yyy
# 1：必须配置非空 ALLOWED_SENDER_OPEN_IDS，否则拒绝启动
# REQUIRE_SENDER_ALLOWLIST=0
# 1：校验白名单每项为 ou_ 格式，否则拒绝启动
# VALIDATE_SENDER_OPEN_ID_FORMAT=0
# 1：关闭「未配白名单」的启动警告（仅开发）
# BRIDGE_SILENCE_INSECURE_ALLOWLIST_WARNING=0
# /health 监听地址；默认 127.0.0.1；绑 0.0.0.0 等会打印安全警告
# BRIDGE_HEALTH_HOST=127.0.0.1
# 1：CURSOR_AGENT_BIN 为绝对路径时须存在；CURSOR_AGENT_WORKSPACE 须存在
# BRIDGE_STRICT_CONFIG=0

# ========== 飞书消息长度（桥接 API 发送）==========
# 纯文本超出则截断；默认 3500；上限 100000（飞书文本类消息请求体官方约 150KB，需预留 JSON 转义）
# lark-cli 由 Agent 本机调用，其限制以飞书开放平台与 CLI 为准，本项不直接改 lark-cli
# BRIDGE_FEISHU_TEXT_MAX_CHARS=3500

# ========== 调试日志（可选）==========
# 1：写入 inbox/debug/（或 BRIDGE_DEBUG_LOG_DIR）：bridge.log + 每轮 agent-*.log（含完整 prompt 与 Agent 流式 JSON）
# BRIDGE_DEBUG_LOG=0
# 自定义目录（绝对路径推荐）
# BRIDGE_DEBUG_LOG_DIR=

# ========== 其它 ==========
# macOS：收到消息时尝试用 Cursor 打开 LATEST.md
CURSOR_OPEN_ON_MESSAGE=0
# 不使用 HTTP /health 时
# BRIDGE_HEALTH_DISABLED=1
# Lark 国际版
# LARK_USE_LARK_INTERNATIONAL=1
