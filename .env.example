# ========== 推荐：长连接（与 OpenClaw 飞书插件一致，无需公网域名）==========
# 参考：飞书文档「使用长连接接收事件」
# https://open.feishu.cn/document/uAjLw4CM/ukTMukTMukTM/event-subscription-guide/long-connection-mode
BRIDGE_MODE=ws

LARK_APP_ID=
LARK_APP_SECRET=

# 国际版 Lark 填 1
# LARK_USE_LARK_INTERNATIONAL=0

# ========== 可选：HTTP Webhook（需要公网 HTTPS + ngrok 等）==========
# BRIDGE_MODE=http
# LARK_ENCRYPT_KEY=
# LARK_VERIFICATION_TOKEN=
# WEBHOOK_PATH=/webhook/feishu

# 长连接模式下仍可用同一端口提供 GET /health；不需要可关闭
PORT=8787
# BRIDGE_HEALTH_DISABLED=1

# 仅处理这些 open_id（逗号分隔）；留空不限制
# ALLOWED_SENDER_OPEN_IDS=ou_xxxx,ou_yyyy

# macOS：收到消息后尝试用 Cursor 打开 LATEST.md
CURSOR_OPEN_ON_MESSAGE=0

# 收到后自动在飞书回「已收到」（需 im 发消息权限）
# LARK_AUTO_ACK=1
