# ========== 飞书长连接 ==========
BRIDGE_MODE=ws
LARK_APP_ID=
LARK_APP_SECRET=
# LARK_USE_LARK_INTERNATIONAL=1

PORT=8787
# BRIDGE_HEALTH_DISABLED=1

# ========== 全自动回复（无需打开 Cursor 对话）==========
# 运行时由 Node 调大模型 HTTP API，经飞书 SDK 发回会话。
AUTO_REPLY_ENABLED=0
# openai | openai-compatible | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# AUTO_REPLY_SYSTEM_PROMPT=
# AUTO_REPLY_MAX_TOKENS=2048
# AUTO_REPLY_TEMPERATURE=0.5

# ========== 半自动 / 调试 ==========
# ALLOWED_SENDER_OPEN_IDS=
CURSOR_OPEN_ON_MESSAGE=0
# 与 AUTO_REPLY 二选一体验更佳；全自动开启时会自动跳过 LARK_AUTO_ACK
# LARK_AUTO_ACK=1

# ========== HTTP Webhook 备选 ==========
# BRIDGE_MODE=http
# LARK_ENCRYPT_KEY=
# LARK_VERIFICATION_TOKEN=
# WEBHOOK_PATH=/webhook/feishu
