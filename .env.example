# ========== 飞书长连接 ==========
LARK_APP_ID=
LARK_APP_SECRET=

PORT=8787

# ========== Cursor Agent 全自动（飞书 ↔ 本机 agent）==========
# 安装 CLI：curl https://cursor.com/install -fsS | bash，然后 agent login
CURSOR_AGENT_AUTO=1
# PATH 中的可执行文件名，一般为 agent
# CURSOR_AGENT_BIN=agent
# Agent 工作区（默认本仓库根目录，建议改为你的项目绝对路径）
# CURSOR_AGENT_WORKSPACE=
CURSOR_AGENT_SANDBOX=disabled
# CURSOR_AGENT_MODEL=
# 飞书进度推送最小间隔（毫秒，仅当 STREAM_TO_FEISHU=1 时有效）
# CURSOR_AGENT_FEISHU_MIN_INTERVAL_MS=5000
# 1/true：把工具调用等过程也发到飞书；默认关，飞书里通常只有一条简洁答复
# CURSOR_AGENT_STREAM_TO_FEISHU=0
# 安静模式下未识别到 lark-cli 时是否由桥接 API 补发（默认开）；0 关闭
# CURSOR_AGENT_QUIET_BRIDGE_FALLBACK=1
# agent 最长运行毫秒，超时 SIGTERM；0=不限制
# CURSOR_AGENT_TIMEOUT_MS=0
# 可选；不填则用 agent login 本机凭据
# CURSOR_API_KEY=

# ========== 其它 ==========
# ALLOWED_SENDER_OPEN_IDS=ou_xxx,ou_yyy
# macOS：收到消息时尝试用 Cursor 打开 LATEST.md
CURSOR_OPEN_ON_MESSAGE=0
# 不使用 HTTP /health 时
# BRIDGE_HEALTH_DISABLED=1
# Lark 国际版
# LARK_USE_LARK_INTERNATIONAL=1
