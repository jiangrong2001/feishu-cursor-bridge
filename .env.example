# ========== 飞书长连接 ==========
BRIDGE_MODE=ws
LARK_APP_ID=
LARK_APP_SECRET=

PORT=8787

# ========== 推荐：真 Cursor Agent 全自动（飞书 ↔ Cursor 双向）==========
# 需安装 Cursor CLI：curl https://cursor.com/install -fsS | bash
# 文档：https://cursor.com/docs/cli/headless
# 与下方 AUTO_REPLY_ENABLED 二选一，勿同时开
CURSOR_AGENT_AUTO=0
# PATH 中的可执行文件名，一般为 agent
# CURSOR_AGENT_BIN=agent
# Agent 工作区（默认本仓库根目录）
# CURSOR_AGENT_WORKSPACE=
# 高权限：disabled = 允许终端等（与文档一致）
CURSOR_AGENT_SANDBOX=disabled
# CURSOR_AGENT_MODEL=
# 飞书进度推送最小间隔（毫秒）
# CURSOR_AGENT_FEISHU_MIN_INTERVAL_MS=5000
# headless 鉴权（或改用 agent login）
# CURSOR_API_KEY=

# ========== 备选：直连 OpenAI/Anthropic（非 Cursor Agent）==========
AUTO_REPLY_ENABLED=0
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ========== 其它 ==========
# ALLOWED_SENDER_OPEN_IDS=
CURSOR_OPEN_ON_MESSAGE=0
# LARK_AUTO_ACK=1

# BRIDGE_MODE=http
# LARK_ENCRYPT_KEY=
# LARK_VERIFICATION_TOKEN=
